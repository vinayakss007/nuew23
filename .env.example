# ============================================================
#  NuCRM Low-Spec — Environment Variables
#  External PostgreSQL + Redis (not included)
# ============================================================

# ── External PostgreSQL (Neon, Supabase, AWS RDS, etc.) ────
DATABASE_URL=postgresql://user:password@host:5432/neondb?sslmode=require
DATABASE_SSL=true
DATABASE_POOL_SIZE=3

# ── External Redis (Upstash, Redis Cloud, etc.) ───────────
REDIS_URL=redis://default:password@host:6379

# ── Authentication Secrets ───────────────────────────────
JWT_SECRET=<generate-with: openssl rand -base64 64>
SETUP_KEY=<generate-with: openssl rand -hex 24>
CRON_SECRET=<generate-with: openssl rand -hex 48>
ENCRYPTION_KEY=<generate-with: openssl rand -hex 32>

# ── Application ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=production
