{
  "name": "nucrm-saas",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS CRM built with Next.js 16, PostgreSQL, and JWT auth",
  "author": "NuCRM Team",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/nucrm/nucrm-saas#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nucrm/nucrm-saas.git"
  },
  "bugs": {
    "url": "https://github.com/nucrm/nucrm-saas/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "crm",
    "saas",
    "multi-tenant",
    "nextjs",
    "postgresql",
    "typescript",
    "customer-relationship-management",
    "lead-management",
    "sales-pipeline"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:check": "node check-db.js",
    "db:push": "npx tsx scripts/push-db.mts",
    "db:auto": "npx tsx scripts/push-db.mts",
    "db:seed": "npx tsx scripts/seed-advanced.ts",
    "db:demo": "npx tsx scripts/seed-massive-data.ts",
    "db:studio": "node -e \"console.log('Use DBeaver or pgAdmin to connect: ' + process.env.DATABASE_URL)\"",
    "setup": "cp -n .env.local.example .env.local && npm run db:auto && echo '\n✅ Run: npm run dev\n'",
    "db:migrate": "npx tsx scripts/push-db.mts",
    "demo:setup": "node setup-demo.js",
    "worker": "tsx worker.ts",
    "worker:dev": "tsx watch worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker:dev\" -c \"blue,bold.yellow\" -n \"APP,WORKER\"",
    "start:app": "next start",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "echo \"E2E tests require Playwright - run 'npx playwright test'\"",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "logs:watch": "node scripts/watch-logs.js",
    "logs:errors": "node scripts/watch-logs.js error",
    "logs:view": "echo '📡 Opening log viewer... && open log-viewer.html || xdg-open log-viewer.html'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1024.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@sentry/nextjs": "10.47.0",
    "@tanstack/react-table": "8.21.3",
    "autoprefixer": "10.4.27",
    "bcryptjs": "3.0.3",
    "bullmq": "5.73.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "csv-stringify": "^6.7.0",
    "date-fns": "4.1.0",
    "dotenv": "17.4.0",
    "ioredis": "5.10.1",
    "jose": "6.2.2",
    "lucide-react": "0.511.0",
    "next": "16.2.1",
    "next-themes": "0.4.6",
    "nodemailer": "8.0.4",
    "pg": "8.20.0",
    "pg-boss": "12.15.0",
    "postcss": "8.5.8",
    "qrcode": "1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "2.6.0",
    "recharts": "2.15.4",
    "resend": "4.8.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "3.4.19"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bcryptjs": "3.0.0",
    "@types/node": "22.19.17",
    "@types/nodemailer": "6.4.23",
    "@types/pg": "8.20.0",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.2",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.1",
    "jsdom": "26.1.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  },
  "overrides": {
    "jsdom": "26.1.0",
    "vitest": "4.1.2",
    "typescript": "5.9.3"
  }
}
